# =============================================================================
# CENG318 — React Native / TypeScript .gitignore
# Covers: Node, Metro, React Native (bare), Expo, iOS, Android, IDEs, OS.
# NOTE: lockfiles (package-lock.json / yarn.lock) and Podfile.lock are NOT
# ignored on purpose — commit them so every teammate builds the same versions.
# =============================================================================

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Node / JavaScript ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo
.eslintcache

# --- Environment & secrets (keep .env.example tracked) ---
.env
.env.*
!.env.example
*.pem
google-services.json
GoogleService-Info.plist

# --- Metro bundler ---
.metro-health-check*

# --- Bundled JS artifacts ---
*.jsbundle

# --- Testing / coverage ---
coverage/

# --- Expo ---
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# --- Native projects ---
# ios/ and android/ are GENERATED by `npx expo prebuild` (run automatically by
# `npx expo run:ios`). They are machine-specific and large, so we never commit
# them — every teammate regenerates them locally. See docs/SETUP.md.
/ios/
/android/

# --- iOS / Xcode (extra safety for stray native files) ---
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.xcuserstate
ios/.xcode.env.local
ios/build/

# --- CocoaPods / Ruby (Podfile.lock stays tracked) ---
ios/Pods/
/vendor/bundle/

# --- Android / Gradle / IntelliJ ---
.idea/
.gradle/
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore
android/app/build/
android/build/
android/.gradle/

# --- fastlane ---
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# --- Yarn (Berry) ---
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# --- Editor / misc ---
*.log
*.swp
*~

# --- Local scratch (preview screenshots, QR, throwaway driver scripts) ---
_screens/
_chrome-prof*/
_cp*/
_*.mjs

# web deploy build artifacts
/dist/
/public_out/
